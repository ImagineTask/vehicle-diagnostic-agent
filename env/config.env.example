# --- Environment ---
ENVIRONMENT=local
LOG_LEVEL=INFO
DEBUG=false

# --- Concurrency ---
MAX_CONCURRENT_DIAGNOSTICS=10
MAX_CONCURRENT_LLM_CALLS=5

# --- Neo4j (non-secret) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_DATABASE=neo4j

# --- Azure OpenAI (non-secret) ---
AZURE_REGION_PRIMARY_ENDPOINT=
AZURE_REGION_PRIMARY_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# --- Gemini ---
GEMINI_USE_VERTEX=false
GEMINI_PROJECT_ID=
GEMINI_LOCATION=us-central1
GEMINI_DEFAULT_MODEL=gemini-2.0-flash-001

# --- Langfuse ---
LANGFUSE_ENABLED=false
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Auth ---
USE_AUTH=false
AUTH_PROVIDER=none
KEYCLOAK_JWKS_URL=
KEYCLOAK_ISSUER=
KEYCLOAK_AUDIENCE=

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
